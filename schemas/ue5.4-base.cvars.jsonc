      "name": "r.PathTracing.TemporalDenoiser",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enable temporal denoising of the path traced output -1: inherit from PostProcessVolume (TODO when out of experimental phase) 0: disable denoiser 1: enable denoiser (if a denoiser plugin is active)",
