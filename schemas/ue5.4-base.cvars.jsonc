    "r.SparseVolumeTexture.Streaming.RequestMipBias": {
      "name": "r.SparseVolumeTexture.Streaming.RequestMipBias",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Bias to apply the calculated mip level to stream at. This is used to account for the mip estimation based on projected screen space size being very conservative. The default value of 1.0 was found empirically to roughly result in a 1:1 voxel to pixel ratio.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
