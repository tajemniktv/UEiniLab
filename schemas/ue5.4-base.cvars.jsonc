    "net.UseAdaptiveNetUpdateFrequency": {
      "name": "net.UseAdaptiveNetUpdateFrequency",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "If 1, NetUpdateFrequency will be calculated based on how often actors actually send something when replicating",
      "category": "Networking",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
