    "r.Shaders.WriteSymbols": {
      "name": "r.Shaders.WriteSymbols",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables writing shader symbols to disk for platforms that support that. This explicitly does not enable generation of shader symbols. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
