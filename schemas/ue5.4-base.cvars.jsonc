    "r.Mobile.DBuffer": {
      "name": "r.Mobile.DBuffer",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables DBuffer decal material blend modes when using the mobile forward renderer. DBuffer decals are rendered before the base pass, allowing them to affect static lighting and skylighting correctly. When enabled, a full prepass will be forced which adds CPU / GPU cost. Several texture lookups will be done in the base pass to fetch the decal properties, which adds pixel work. 0: off (default) 1: on",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
