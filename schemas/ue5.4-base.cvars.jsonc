    "r.SceneCulling": {
      "name": "r.SceneCulling",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enable/Disable scene culling. While enabled, it will only build the instance hierarchy if used by any system - currently that corresponds to Nanite being enabled. Forces a recreate of all render state since (at present) there is only an incremental update path.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
