    "r.Shadow.Virtual.ShowLightDrawEvents": {
      "name": "r.Shadow.Virtual.ShowLightDrawEvents",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enable Virtual Shadow Maps per-light draw events - may affect performance especially when there are many small lights in the scene.",
