    "r.GlobalDistanceField.Debug.DrawModifiedPrimitives": {
      "name": "r.GlobalDistanceField.Debug.DrawModifiedPrimitives",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Whether to draw primitive modifications (add, remove, updatetransform) that caused an update of the global distance field. This can be useful for tracking down why updating the global distance field is always costing a lot, since it should be mostly cached.",
