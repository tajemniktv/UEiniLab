    "r.SSS.Burley.BilateralFilterKernelFunctionType": {
      "name": "r.SSS.Burley.BilateralFilterKernelFunctionType",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "0: Depth Only. It is more performant (x2 faster for close view).1: Depth and normal. It leads to better quality in regions like eyelids. (default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
