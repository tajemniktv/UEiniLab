    "r.DepthOfFieldQuality": {
      "name": "r.DepthOfFieldQuality",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Allows to adjust the depth of field quality. Currently only fully affects BokehDOF. GaussianDOF is either 0 for off, otherwise on. 0: Off 1: Low 2: high quality (default, adaptive, can be 4x slower) 3: very high quality, intended for non realtime cutscenes, CircleDOF only (slow) 4: extremely high quality, intended for non realtime cutscenes, CircleDOF only (very slow)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
