    "r.Shadow.TransitionScale": {
      "name": "r.Shadow.TransitionScale",
      "kind": "variable",
      "type": "int",
      "defaultValue": "60",
      "help": "This controls the 'fade in' region between a caster and where its shadow shows up. Larger values make a smaller region which will have more self shadowing artifacts",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
