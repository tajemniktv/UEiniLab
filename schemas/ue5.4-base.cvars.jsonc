      "name": "au.streamcaching.PrimeSoundOnAudioComponents",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When set to 1, automatically primes a USoundBase when a UAudioComponent is spawned with that sound, or when UAudioComponent::SetSound is called.",
