    "r.SSS.Quality": {
      "name": "r.SSS.Quality",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Defines the quality of the recombine pass when using the SubsurfaceScatteringProfile shading model 0: low (faster, default) 1: high (sharper details but slower) -1: auto, 1 if TemporalAA is disabled (without TemporalAA the quality is more noticable)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
