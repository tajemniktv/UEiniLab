    "r.Shadow.Virtual.SMRT.AdaptiveRayCount": {
      "name": "r.Shadow.Virtual.SMRT.AdaptiveRayCount",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Shoot fewer rays in fully shadowed and unshadowed regions. Currently only supported with OnePassProjection.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.SMRT.ExtrapolateMaxSlopeDirectional": {
      "name": "r.Shadow.Virtual.SMRT.ExtrapolateMaxSlopeDirectional",
      "kind": "variable",
      "type": "int",
      "defaultValue": "5",
      "help": "Maximum depth slope when extrapolating behind occluders for directional lights. Higher values allow softer penumbra edges but can introduce light leaks behind second occluders. Setting to 0 will disable slope extrapolation slightly improving projection performance, at the cost of reduced penumbra quality.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.SMRT.ExtrapolateMaxSlopeLocal": {
      "name": "r.Shadow.Virtual.SMRT.ExtrapolateMaxSlopeLocal",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.05",
      "help": "Maximum depth slope when extrapolating behind occluders for local lights. Higher values allow softer penumbra edges but can introduce light leaks behind second occluders. Setting to 0 will disable slope extrapolation slightly improving projection performance, at the cost of reduced penumbra quality.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.SMRT.MaxRayAngleFromLight": {
      "name": "r.Shadow.Virtual.SMRT.MaxRayAngleFromLight",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.03",
      "help": "Max angle (in radians) a ray is allowed to span from the light's perspective for local lights.Smaller angles limit the screen space size of shadow penumbra. Larger angles lead to more noise.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
