    "r.PathTracing.Substrate.UseSimplifiedMaterials": {
      "name": "r.PathTracing.Substrate.UseSimplifiedMaterials",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Instead of evaluating all layers, use an optimized material in which all slabs have been merged. This is mainly intended for debugging and requires r.PathTracing.Substrate.CompileSimplifiedMaterials to be true. 0: off (default) 1: on",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
