      "name": "r.PathTracing.MeshDecalRoughnessCutoff",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.15",
      "help": "Do not evaluate mesh decals beyond this roughness level to improve performance (default=0.15)",
