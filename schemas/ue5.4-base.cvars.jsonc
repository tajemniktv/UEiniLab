    "r.Shadow.UseOctreeForCulling": {
      "name": "r.Shadow.UseOctreeForCulling",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether to use the primitive octree for shadow subject culling. The octree culls large groups of primitives at a time, but introduces cache misses walking the data structure.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.AccumulateStats": {
      "name": "r.Shadow.Virtual.AccumulateStats",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When enabled, VSM stats will be collected over multiple frames and written to a CSV file",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.AllocatePagePoolAsReservedResource": {
      "name": "r.Shadow.Virtual.AllocatePagePoolAsReservedResource",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Allocate VSM page pool as a reserved/virtual texture, backed by N small physical memory allocations to reduce fragmentation.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache": {
      "name": "r.Shadow.Virtual.Cache",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Turn on to enable caching",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.AllocateViaLRU": {
      "name": "r.Shadow.Virtual.Cache.AllocateViaLRU",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Prioritizes keeping more recently requested cached physical pages when allocating for new requests.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.ClipmapPanning": {
      "name": "r.Shadow.Virtual.Cache.ClipmapPanning",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enable support for panning cached clipmap pages for directional lights, allowing re-use of cached data when the camera moves. Keep this enabled outside of debugging.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.DebugSkipDynamicPageInvalidation": {
      "name": "r.Shadow.Virtual.Cache.DebugSkipDynamicPageInvalidation",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Skip invalidation of cached pages when geometry moves for debugging purposes. This will create obvious visual artifacts when disabled.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.DeformableMeshesInvalidate": {
      "name": "r.Shadow.Virtual.Cache.DeformableMeshesInvalidate",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "If enabled, Primitive Proxies that are marked as having deformable meshes (HasDeformableMesh() == true) cause invalidations regardless of whether their transforms are updated.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.DrawInvalidatingBounds": {
      "name": "r.Shadow.Virtual.Cache.DrawInvalidatingBounds",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Turn on debug render cache invalidating instance bounds, heat mapped by number of pages invalidated. 1 = Draw all bounds. 2 = Draw those invalidating static cached pages only 3 = Draw those invalidating dynamic cached pages only",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.ForceInvalidateDirectional": {
      "name": "r.Shadow.Virtual.Cache.ForceInvalidateDirectional",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Forces the clipmap to always invalidate, useful to emulate a moving sun to avoid misrepresenting cache performance.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.InvalidateUseHZB": {
      "name": "r.Shadow.Virtual.Cache.InvalidateUseHZB",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When enabled, instances invalidations are tested against the HZB. Instances that are fully occluded will not cause page invalidations.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.MaxPageAgeSinceLastRequest": {
      "name": "r.Shadow.Virtual.Cache.MaxPageAgeSinceLastRequest",
      "kind": "variable",
      "type": "int",
      "defaultValue": "3",
      "help": "The maximum number of frames to allow cached pages that aren't requested in the current frame to live. 0=disabled.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.StaticSeparate": {
      "name": "r.Shadow.Virtual.Cache.StaticSeparate",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When enabled, caches static objects in separate pages from dynamic objects. This can improve performance in largely static scenes, but doubles the memory cost of the physical page pool.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Cache.StaticSeparate.FramesStaticThreshold": {
      "name": "r.Shadow.Virtual.Cache.StaticSeparate.FramesStaticThreshold",
      "kind": "variable",
      "type": "int",
      "defaultValue": "100",
      "help": "Number of frames without an invalidation before an object will transition to static caching.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.FirstCoarseLevel": {
      "name": "r.Shadow.Virtual.Clipmap.FirstCoarseLevel",
      "kind": "variable",
      "type": "int",
      "defaultValue": "15",
      "help": "First level of the clipmap to mark coarse pages for. Lower values allow higher resolution coarse pages near the camera but increase total page counts.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.FirstLevel": {
      "name": "r.Shadow.Virtual.Clipmap.FirstLevel",
      "kind": "variable",
      "type": "int",
      "defaultValue": "6",
      "help": "First level of the virtual clipmap. Lower values allow higher resolution shadows closer to the camera, but may increase page count.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.GreedyLevelSelection": {
      "name": "r.Shadow.Virtual.Clipmap.GreedyLevelSelection",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When enabled, allows greedily sampling more detailed clipmap levels if they happen to be mapped. This can increase shadow quality from certain viewing angles, but makes the clipmap boundry less stable which can exacerbate visual artifacts at low shadow resolutions.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.LastCoarseLevel": {
      "name": "r.Shadow.Virtual.Clipmap.LastCoarseLevel",
      "kind": "variable",
      "type": "int",
      "defaultValue": "18",
      "help": "Last level of the clipmap to mark coarse pages for. Higher values provide dense clipmap data for a longer radius but increase total page counts.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.LastLevel": {
      "name": "r.Shadow.Virtual.Clipmap.LastLevel",
      "kind": "variable",
      "type": "int",
      "defaultValue": "22",
      "help": "Last level of the virtual clipmap. Indirectly determines radius the clipmap can cover. Each extra level doubles the maximum range, but may increase page count.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.MinCameraViewportWidth": {
      "name": "r.Shadow.Virtual.Clipmap.MinCameraViewportWidth",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "If greater than zero, clamps the camera viewport dimensions used to adjust the clipmap resolution. This can be useful to avoid dynamic resolution indirectly dropping the shadow resolution far too low.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.UseConservativeCulling": {
      "name": "r.Shadow.Virtual.Clipmap.UseConservativeCulling",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Conservative culling removes the frustum-clipped culling volume for the non-nanite geometry for VSM rendering. This means a lot more geometry is submitted, and also marked as rendered. Useful to diagnose if there are culling artifacts in virtual shadow map clip maps due to errors in the tracking code.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.WPODisableDistance": {
      "name": "r.Shadow.Virtual.Clipmap.WPODisableDistance",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When enabled, disables WPO animation in clipmap levels based on a primitive's WPO disable distance and r.Shadow.Virtual.Clipmap.WPODisableDistance.LodBias setting.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.WPODisableDistance.LodBias": {
      "name": "r.Shadow.Virtual.Clipmap.WPODisableDistance.LodBias",
      "kind": "variable",
      "type": "int",
      "defaultValue": "3",
      "help": "The number of clipmap levels further than the distance that an instance would be animated to allow shadow animation. Typically 2-4 works well but may need to be adjusted for very low light angles with significant WPO movement.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Clipmap.ZRangeScale": {
      "name": "r.Shadow.Virtual.Clipmap.ZRangeScale",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1000",
      "help": "Scale of the clipmap level depth range relative to the radius. Affects z-near/z-far of the shadow map. Should generally be at least 10 or it will result in excessive cache invalidations. Values that are too large cause depth imprecisions and shadow flickering.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.CoarsePagePixelThresholdDynamic": {
      "name": "r.Shadow.Virtual.CoarsePagePixelThresholdDynamic",
      "kind": "variable",
      "type": "int",
      "defaultValue": "16",
      "help": "If a dynamic (non-nanite) instance has a smaller estimated pixel footprint than this value, it should not be drawn into a coarse page. Higher values cull away more instances.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.CoarsePagePixelThresholdDynamicNanite": {
      "name": "r.Shadow.Virtual.CoarsePagePixelThresholdDynamicNanite",
      "kind": "variable",
      "type": "int",
      "defaultValue": "4",
      "help": "If a dynamic Nanite instance has a smaller estimated pixel footprint than this value, it should not be drawn into a coarse page. Higher values cull away more instances. This value is typically lower than the non-Nanite one because Nanite has lower overhead for drawing small objects.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.CoarsePagePixelThresholdStatic": {
      "name": "r.Shadow.Virtual.CoarsePagePixelThresholdStatic",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "If a static (non-nanite) instance has a smaller estimated pixel footprint than this value, it should not be drawn into a coarse page. Higher values cull away more instances. This value is typically lower than the non-static one because the static pages have better caching.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.CullBackfacingPixels": {
      "name": "r.Shadow.Virtual.CullBackfacingPixels",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When enabled does not generate shadow data for pixels that are backfacing to the light.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.DebugSkipMergePhysical": {
      "name": "r.Shadow.Virtual.DebugSkipMergePhysical",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Skip the merging of the static VSM cache into the dynamic one. This will create obvious visual artifacts when disabled.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.DistantLightForceCacheFootprintFraction": {
      "name": "r.Shadow.Virtual.DistantLightForceCacheFootprintFraction",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Fraction of footprint size below which start force-caching lights that are invalidated (i.e., are moving or re-added) Larger values may improve performance but may also produce more visible artifacts The base footprint is based on the page size. 0.0 == Never force-cache (default), 1.0 == Always force-cache.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.DistantLightMode": {
      "name": "r.Shadow.Virtual.DistantLightMode",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Control whether distant light mode is enabled for local lights. 0 == Off, 1 == On (default), 2 == Force All. When on, lights with a pixel footprint below the threshold are marked as distant. Updates to distant lights are throttled (force-cached), they use simpler page-table logic and the memory cost is lower.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.DynamicRes.MaxPagePoolLoadFactor": {
      "name": "r.Shadow.Virtual.DynamicRes.MaxPagePoolLoadFactor",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.85",
      "help": "If allocation exceeds this factor of total page pool capacity, shadow resolution will be biased downwards. 0 = disabled",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.DynamicRes.MaxResolutionLodBias": {
      "name": "r.Shadow.Virtual.DynamicRes.MaxResolutionLodBias",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "As page allocation approaches the pool capacity, VSM resolution ramps down by biasing the LOD up, similar to 'ResolutionLodBiasDirectional'. This is the maximum LOD bias to clamp to for global dynamic shadow resolution reduction. 0 = disabled",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Enable": {
      "name": "r.Shadow.Virtual.Enable",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enable Virtual Shadow Maps. Renders geometry into virtualized shadow depth maps for shadowing. Provides high - quality shadows for next - gen projects with simplified setup.High efficiency culling when used with Nanite.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ForceFullHZBUpdate": {
      "name": "r.Shadow.Virtual.ForceFullHZBUpdate",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Forces full HZB update every frame rather than just dirty pages.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ForceOnlyVirtualShadowMaps": {
      "name": "r.Shadow.Virtual.ForceOnlyVirtualShadowMaps",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "If enabled, disallow creation of conventional non-virtual shadow maps for any lights that get a virtual shadow map. This can improve performance and save memory, but any geometric primitives that cannot be rendered into the virtual shadow map will not cast shadows.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ForcePerLightShadowMaskClear": {
      "name": "r.Shadow.Virtual.ForcePerLightShadowMaskClear",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "For debugging purposes. When enabled, the shadow mask texture is cleared before the projection pass writes to it. Projection pass writes all relevant pixels, so clearing should be unnecessary.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.MarkCoarsePagesDirectional": {
      "name": "r.Shadow.Virtual.MarkCoarsePagesDirectional",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Marks coarse pages in directional light virtual shadow maps so that low resolution data is available everywhere.Ability to disable is primarily for profiling and debugging.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.MarkCoarsePagesLocal": {
      "name": "r.Shadow.Virtual.MarkCoarsePagesLocal",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Marks coarse pages in local light virtual shadow maps so that low resolution data is available everywhere.Ability to disable is primarily for profiling and debugging.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.MarkPixelPages": {
      "name": "r.Shadow.Virtual.MarkPixelPages",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Marks pages in virtual shadow maps based on depth buffer pixels. Ability to disable is primarily for profiling and debugging.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.MarkPixelPagesMipModeLocal": {
      "name": "r.Shadow.Virtual.MarkPixelPagesMipModeLocal",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When enabled, this uses a subset of mips to reduce instance duplication in VSMs. Will result in better performance but a harsher falloff on mip transitions. 0 - Disabled: Use all 8 mips 1 - Quality Mode: Use 4 higher res mips (16k, 4k, 1k, 256) 2 - Performance Mode: Use 4 lower res mips (8k, 2k, 512, 128)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.MaxDistantUpdatePerFrame": {
      "name": "r.Shadow.Virtual.MaxDistantUpdatePerFrame",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Maximum number of distant lights to update each frame. Invalidated lights that were missed may be updated in a later frame (round-robin).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.MaxPhysicalPages": {
      "name": "r.Shadow.Virtual.MaxPhysicalPages",
      "kind": "variable",
      "type": "int",
      "defaultValue": "4096",
      "help": "Maximum number of physical pages in the pool. More space for pages means more memory usage, but allows for higher resolution shadows. Ideally this value is large enough to fit enough pages for all the lights in the scene, but not too large to waste memory. Enable 'ShowStats' to see how many pages are allocated in the pool right now. For more page pool control, see the 'ResolutionLodBias', 'DynamicRes.' and 'Cache.StaticSeparate' cvars.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.Nanite.MaterialVisibility": {
      "name": "r.Shadow.Virtual.Nanite.MaterialVisibility",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enable Nanite CPU-side visibility filtering of draw commands, depends on r.Nanite.MaterialVisibility being enabled.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.Batch": {
      "name": "r.Shadow.Virtual.NonNanite.Batch",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": ".",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.CulledInstanceAllocationFactor": {
      "name": "r.Shadow.Virtual.NonNanite.CulledInstanceAllocationFactor",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Allocation size scale factor for the buffer used to store instances after culling. The total size accounts for the worst-case scenario in which all instances are emitted into every clip or mip level. This is far more than we'd expect in reasonable circumstances, so this scale factor is used to reduce memory pressure. The actual number cannot be known on the CPU as the culling emits an instance for each clip/mip level that is overlapped. Setting to 1.0 is fully conservative. Lowering this is likely to produce artifacts unless you're certain the buffer won't overflow.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.IncludeInCoarsePages": {
      "name": "r.Shadow.Virtual.NonNanite.IncludeInCoarsePages",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Include non-Nanite geometry in coarse pages.Rendering non-Nanite geometry into large coarse pages can be expensive; disabling this can be a significant performance win.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.LargeInstancePageAreaThreshold": {
      "name": "r.Shadow.Virtual.NonNanite.LargeInstancePageAreaThreshold",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "How large area is considered a 'large' footprint, summed over all overlapped levels, if set to -1 uses the physical page pool size / 8. Used as a threshold when storing page area coverage stats for diagnostics.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.MaxCulledInstanceAllocationSize": {
      "name": "r.Shadow.Virtual.NonNanite.MaxCulledInstanceAllocationSize",
      "kind": "variable",
      "type": "int",
      "defaultValue": "134217728",
      "help": "Maximum number of instances that may be output from the culling pass into all VSM mip/clip levels. At 12 byte per instance reference this represents a 1.5GB clamp.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.NumPageAreaDiagSlots": {
      "name": "r.Shadow.Virtual.NonNanite.NumPageAreaDiagSlots",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Number of slots in diagnostics to report non-nanite instances with the largest page area coverage, < 0 uses the max number allowed, 0 disables.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNanite.SinglePassBatched": {
      "name": "r.Shadow.Virtual.NonNanite.SinglePassBatched",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": ".",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
