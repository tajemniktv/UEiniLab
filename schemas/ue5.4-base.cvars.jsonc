    "r.PathTracing.MISCompensation": {
      "name": "r.PathTracing.MISCompensation",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Activates MIS compensation for skylight importance sampling. (default = 1 (enabled)) This option only takes effect when r.PathTracing.MISMode = 2",
