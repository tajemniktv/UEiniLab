    "r.Upscale.Panini.ScreenFit": {
      "name": "r.Upscale.Panini.ScreenFit",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Panini projection screen fit effect factor (lerp). 0: fit vertically 1: fit horizontally (default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
