    "r.RHICmdFlushRenderThreadTasksBasePass": {
      "name": "r.RHICmdFlushRenderThreadTasksBasePass",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Wait for completion of parallel render thread tasks at the end of the base pass. A more granular version of r.RHICmdFlushRenderThreadTasks. If either r.RHICmdFlushRenderThreadTasks or r.RHICmdFlushRenderThreadTasksBasePass is > 0 we will flush.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
