      "name": "au.streamcaching.PlaybackRequestPriority",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "This cvar sets the default request priority for audio chunks that are about to play back, but aren't in the cache. 0: High, 1: Normal, 2: Below Normal, 3: Low, 4: Min",
      "category": "Audio",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
