    "r.RayTracing.UseTextureLod": {
      "name": "r.RayTracing.UseTextureLod",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enable automatic texture mip level selection in ray tracing material shaders. 0: highest resolution mip level is used for all texture (default). 1: texture LOD is approximated based on total ray length, output resolution and texel density at hit point (ray cone method).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
