      "name": "au.streamcaching.EnableExhaustiveCacheSearches",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables an exhaustive search of the cache in FindElementForKey. 0: Rely on chunk offset. 1: Search using linear search",
      "category": "Audio",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
