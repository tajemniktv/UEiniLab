    "r.PathTracing.ProgressDisplay": {
      "name": "r.PathTracing.ProgressDisplay",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enables an in-frame display of progress towards the defined sample per pixel limit. The indicator dissapears when the maximum is reached and sample accumulation has stopped (default = 1) 0: off 1: on (default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
