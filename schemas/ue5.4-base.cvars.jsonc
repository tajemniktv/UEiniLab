    "r.FreezeMouseCursor": {
      "name": "r.FreezeMouseCursor",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Free the mouse cursor position, for passes which use it to display debug information. 0: default 1: freeze mouse cursor position at current location",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
