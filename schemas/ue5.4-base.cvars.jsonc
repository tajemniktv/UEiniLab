    "r.RayTracing.Geometry.Cable.WPO.Culling": {
      "name": "r.RayTracing.Geometry.Cable.WPO.Culling",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enable culling for WPO evaluation for cable meshes in ray tracing (default = 1 (Culling enabled))",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
