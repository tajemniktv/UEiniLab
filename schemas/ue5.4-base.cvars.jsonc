    "r.PathTracing.IndirectDispatch": {
      "name": "r.PathTracing.IndirectDispatch",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables indirect dispatch (if supported by the hardware) for compacted path tracing (default: 0 (disabled))",
