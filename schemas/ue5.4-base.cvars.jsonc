    "r.RayTracing.Transmission.SamplingTechnique": {
      "name": "r.RayTracing.Transmission.SamplingTechnique",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "0: Uses constant tracking of an infinite homogeneous medium 1: Uses constant tracking of a finite homogeneous medium whose extent is determined by transmission sampling distance (default)",
      "category": "Rendering",
