    "r.PathTracing.SSSGuidingRatio": {
      "name": "r.PathTracing.SSSGuidingRatio",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.5",
      "help": "Sets the ratio between classical random walks and walks guided towards the surface. A value of 0.0 corresponds to a purely classical random walk, while a value of 1.0 is fully guided towards the surface (at the expense of fireflies in non-flat regions of the model. (default = 0.5)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
