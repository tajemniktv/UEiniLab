    "r.GaussianBloom.Cross": {
      "name": "r.GaussianBloom.Cross",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Experimental feature to give bloom kernel a more bright center sample (values between 1 and 3 work without causing aliasing) Existing bloom get lowered to match the same brightness <0 for a anisomorphic lens flare look (X only) 0 off (default) >0 for a cross look (X and Y)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
