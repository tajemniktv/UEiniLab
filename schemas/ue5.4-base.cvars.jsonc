      "name": "r.PathTracing.MISMode",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Selects the sampling technique for light integration (default = 2 (MIS enabled)) 0: Material sampling 1: Light sampling 2: MIS betwen material and light sampling (default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
