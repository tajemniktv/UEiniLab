    "r.Shadow.Virtual.NonNanite.UseHZB": {
      "name": "r.Shadow.Virtual.NonNanite.UseHZB",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Cull Non-Nanite instances using HZB. Set to 0 to disable. Set to 1 to use HZB from previous frame. Can incorrectly cull in some cases due to outdated data. Set to 2 to use two-pass Nanite culling with HZB from the current frame.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NonNaniteVSM": {
      "name": "r.Shadow.Virtual.NonNaniteVSM",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enable support for non-nanite Virtual Shadow Maps.Read-only and to be set in a config file (requires restart).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.NormalBias": {
      "name": "r.Shadow.Virtual.NormalBias",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.5",
      "help": "Receiver offset along surface normal for shadow lookup. Scaled by distance to camera.Higher values avoid artifacts on surfaces nearly parallel to the light, but also visibility offset shadows and increase the chance of hitting unmapped pages.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.OnePassProjection": {
      "name": "r.Shadow.Virtual.OnePassProjection",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Projects all local light virtual shadow maps in a single pass for better performance.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.OnePassProjection.MaxLightsPerPixel": {
      "name": "r.Shadow.Virtual.OnePassProjection.MaxLightsPerPixel",
      "kind": "variable",
      "type": "int",
      "defaultValue": "16",
      "help": "Maximum lights per pixel that get full filtering when using one pass projection and clustered shading.Generally set to 8 (32bpp), 16 (64bpp) or 32 (128bpp). Lower values require less transient VRAM during the lighting pass.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.OnePassProjection.SkipScreenShadowMask": {
      "name": "r.Shadow.Virtual.OnePassProjection.SkipScreenShadowMask",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Allows skipping the screen space shadow mask entirely when only a virtual shadow map would write into it. Should generally be left enabled outside of debugging.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.PageDilationBorderSizeDirectional": {
      "name": "r.Shadow.Virtual.PageDilationBorderSizeDirectional",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.05",
      "help": "If a screen pixel falls within this fraction of a page border for directional lights, the adacent page will also be mapped.Higher values can reduce page misses at screen edges or disocclusions, but increase total page counts.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.PageDilationBorderSizeLocal": {
      "name": "r.Shadow.Virtual.PageDilationBorderSizeLocal",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.05",
      "help": "If a screen pixel falls within this fraction of a page border for local lights, the adacent page will also be mapped.Higher values can reduce page misses at screen edges or disocclusions, but increase total page counts.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.PageMarkingPixelStrideX": {
      "name": "r.Shadow.Virtual.PageMarkingPixelStrideX",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "During page marking, instead of testing every screen pixel, test every Nth pixel. Page marking from screen pixels is used to determine which VSM pages are seen from the camera and need to be rendered. Increasing this value reduces page-marking costs, but could introduce artifacts due to missing pages. With sufficiently low values, it is likely a neighbouring pixel will mark the required page anyway.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.PageMarkingPixelStrideY": {
      "name": "r.Shadow.Virtual.PageMarkingPixelStrideY",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Same as PageMarkingPixelStrideX, but on the vertical axis of the screen.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ResolutionLodBiasDirectional": {
      "name": "r.Shadow.Virtual.ResolutionLodBiasDirectional",
      "kind": "variable",
      "type": "float",
      "defaultValue": "-1.5",
      "help": "Bias applied to LOD calculations for directional lights. -1.0 doubles resolution, 1.0 halves it and so on.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ResolutionLodBiasDirectionalMoving": {
      "name": "r.Shadow.Virtual.ResolutionLodBiasDirectionalMoving",
      "kind": "variable",
      "type": "float",
      "defaultValue": "-1.5",
      "help": "Bias applied to LOD calculations for directional lights that are moving. -1.0 doubles resolution, 1.0 halves it and so on. The bias transitions smoothly back to ResolutionLodBiasDirectional as the light transitions to non-moving, see 'r.Shadow.Scene.LightActiveFrameCount'.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ResolutionLodBiasLocal": {
      "name": "r.Shadow.Virtual.ResolutionLodBiasLocal",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Bias applied to LOD calculations for local lights. -1.0 doubles resolution, 1.0 halves it and so on.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ResolutionLodBiasLocalMoving": {
      "name": "r.Shadow.Virtual.ResolutionLodBiasLocalMoving",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Bias applied to LOD calculations for local lights that are moving. -1.0 doubles resolution, 1.0 halves it and so on. The bias transitions smoothly back to ResolutionLodBiasLocal as the light transitions to non-moving, see 'r.Shadow.Scene.LightActiveFrameCount'.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.Virtual.ScreenRayLength": {
      "name": "r.Shadow.Virtual.ScreenRayLength",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.015",
      "help": "Length of the screen space shadow trace away from receiver surface (smart shadow bias) before the VSM / SMRT lookup.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
