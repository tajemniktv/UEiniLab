      "name": "r.RDG.ClobberResources",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Clears all render targets and texture / buffer UAVs with the requested clear color at allocation time. Useful for debugging. 0:off (default); 1: 1000 on RGBA channels; 2: NaN on RGBA channels; 3: +INFINITY on RGBA channels.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
