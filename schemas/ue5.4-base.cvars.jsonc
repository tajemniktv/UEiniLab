    "r.XGEController.AvoidUsingLocalMachine": {
      "name": "r.XGEController.AvoidUsingLocalMachine",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether XGE tasks should avoid running on the local machine (to reduce the oversubscription with local async and out-of-process work). 0: Do not avoid. Distributed tasks will be spawned on all available XGE agents. Can cause oversubscription on the initiator machine. 1: Avoid spawning tasks on the local (initiator) machine except when running a commandlet or -buildmachine is passed (default). 2: Avoid spawning tasks on the local (initiator) machine.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
