    "r.DBuffer": {
      "name": "r.DBuffer",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enables DBuffer decal material blend modes. DBuffer decals are rendered before the base pass, allowing them to affect static lighting and skylighting correctly. When enabled, a full prepass will be forced which adds CPU / GPU cost. Several texture lookups will be done in the base pass to fetch the decal properties, which adds pixel work. 0: off 1: on (default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
