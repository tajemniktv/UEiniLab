    "r.PathTracing.LightFunctionColor": {
      "name": "r.PathTracing.LightFunctionColor",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables light functions to be colored instead of greyscale (default = 0) 0: off (default) 1: on (light function material output is used directly instead of converting to greyscale)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
