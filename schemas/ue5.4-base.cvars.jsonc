      "name": "r.SSS.Burley.EnableProfileIdCache",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "0: Disable profile id cache using in the sampling pass. 1: Consumes 1 byte per pixel more memory to make Burley pass much faster. (default)",
