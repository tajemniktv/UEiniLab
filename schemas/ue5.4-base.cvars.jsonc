    "r.FXAA.Quality": {
      "name": "r.FXAA.Quality",
      "kind": "variable",
      "type": "int",
      "defaultValue": "4",
      "help": "Selects the quality permutation of FXAA. 0: Console 1: PC medium-dither 3-sample 2: PC medium-dither 5-sample 3: PC medium-dither 8-sample 4: PC low-dither 12-sample (Default) 5: PC extrem quality 12-samples",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
