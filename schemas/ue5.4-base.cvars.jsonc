    "au.RealtimeDecompressZeroDurationSounds": {
      "name": "au.RealtimeDecompressZeroDurationSounds",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When set to 1, we will fallback to realtime decoding any sound waves with an invalid duration.. 0: Fully decompress sounds with a duration of 0, 1: realtime decompress sounds with a duration of 0.",
