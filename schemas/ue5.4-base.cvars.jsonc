      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When set to 1, we will always dispatch a callback to the game thread whenever a USoundWave request has finished. This may cause chunks of audio to be evicted by the time we need them. 0: as soon as the chunk is loaded, capture the audio chunk. 1: As soon as the chunk is loaded, dispatch a callback to the gamethread.",
      "category": "Audio",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
