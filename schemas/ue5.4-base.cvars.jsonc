      "name": "r.PathTracing.Substrate.CompileSimplifiedMaterials",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Compile a simplified representation of Substrate materials which merges all slabs into one. This is mainly intended for debugging purposes. Enabling this double the number of path tracing shader permutations. 0: off (default) 1: on",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
