    "r.PathTracing.AtmosphereOpticalDepthLUTResolution": {
      "name": "r.PathTracing.AtmosphereOpticalDepthLUTResolution",
      "kind": "variable",
      "type": "int",
      "defaultValue": "512",
      "help": "Size of the square lookup texture used for transmittance calculations by the path tracer in reference atmosphere mode. (default = 512)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
