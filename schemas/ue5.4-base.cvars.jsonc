    "r.PathTracing.MaxPathIntensity": {
      "name": "r.PathTracing.MaxPathIntensity",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "When positive, light paths greater that this amount are clamped to prevent fireflies (default = -1 (driven by postprocesing volume))",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
