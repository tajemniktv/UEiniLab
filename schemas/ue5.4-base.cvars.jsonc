    "r.PathTracing.LightGridMaxCount": {
      "name": "r.PathTracing.LightGridMaxCount",
      "kind": "variable",
      "type": "int",
      "defaultValue": "128",
      "help": "Controls the maximum number of lights per cell in the 2D light grid. The minimum of this value and the number of lights in the scene is used. (default = 128)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
