      "name": "au.streamcaching.EnableTrimmingRetainedAudio",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When set > 0, we will trim retained audio when the stream cache goes over the memory limit. 0: never trims retained audio, >0: will trim retained audio.",
      "category": "Audio",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
