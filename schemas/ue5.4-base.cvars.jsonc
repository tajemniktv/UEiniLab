    "r.PathTracing.FlushDispatch": {
      "name": "r.PathTracing.FlushDispatch",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Enables flushing of the command list after dispatch to reduce the likelyhood of TDRs on Windows (default: 2) 0: off 1: flush after each dispatch 2: flush after each tile",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
