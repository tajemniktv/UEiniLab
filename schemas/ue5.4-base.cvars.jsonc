      "name": "r.PathTracing.SpatialDenoiser",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enable spatial denoising of the path traced output -1: inherit from PostProcessVolume 0: disable denoiser 1: enable denoiser (if a denoiser plugin is active)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
