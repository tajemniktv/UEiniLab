    "r.PathTracing.SamplerType": {
      "name": "r.PathTracing.SamplerType",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Controls the way the path tracer generates its random numbers 0: use a different high quality random sequence per pixel (default) 1: optimize the random sequence across pixels to reduce visible error at the target sample count",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
