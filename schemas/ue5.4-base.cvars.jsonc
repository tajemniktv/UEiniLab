    "r.Shadow.TexelsPerPixelSpotlight": {
      "name": "r.Shadow.TexelsPerPixelSpotlight",
      "kind": "variable",
      "type": "float",
      "defaultValue": "2.54648",
      "help": "The ratio of subject pixels to shadow texels for spotlights",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
