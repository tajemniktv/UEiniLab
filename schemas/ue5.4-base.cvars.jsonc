    "r.RayTracing.Translucency.MaxRayDistance": {
      "name": "r.RayTracing.Translucency.MaxRayDistance",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Sets the maximum ray distance for ray traced translucency rays. When ray shortening is used, skybox will not be sampled in RT translucency pass and will be composited later, together with local reflection captures. Negative values turn off this optimization. (default = -1 (infinite rays))",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
