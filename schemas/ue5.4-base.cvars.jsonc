    "r.Ortho.AllowNearPlaneCorrection": {
      "name": "r.Ortho.AllowNearPlaneCorrection",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "true",
      "help": "Orthographic near planes can be behind the camera position, which causes some issues with Unreal resolving lighting behind the camera position This CVar enables the Orthographic cameras globally to automatically update the camera location to match the NearPlane location, and force the pseudo camera position to be the replaced near plane location for the projection matrix calculation. This means Unreal can resolve lighting behind the camera correctly.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Ortho.AutoPlanes": {
      "name": "r.Ortho.AutoPlanes",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "true",
      "help": "Globally allow Ortho cameras to utilise the automatic Near/Far plane evaluations.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Ortho.AutoPlanes.ClampToMaxFPBuffer": {
      "name": "r.Ortho.AutoPlanes.ClampToMaxFPBuffer",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When auto evaluating clip planes, determines whether 16bit depth scaling should be used.16bit scaling is advantageous for any depth downscaling that occurs (e.g. HZB downscaling uses 16 bit textures instead of 32).This feature will calculate the maximum depth scale needed based on the Unreal Unit (cm by default) to Pixel ratio.It assumes that we don't need 32bit depth range for smaller scenes, because most actors will be within a reasonable visible frustumHowever it does still scale up to a maximum of UE_OLD_WORLD_MAX which is the typical full range of the depth buffer, so larger scenes still work too.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Ortho.AutoPlanes.DepthScale": {
      "name": "r.Ortho.AutoPlanes.DepthScale",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Allows the 16 bit depth scaling to be adjusted from the default +FP16 Max (66504.0f)This is useful if the far plane doesn't need to be as far away, so it will improve depth deltas",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Ortho.AutoPlanes.ScaleIncrementingUnits": {
      "name": "r.Ortho.AutoPlanes.ScaleIncrementingUnits",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "true",
      "help": "Select whether to scale the Near/Far plane Min/Max values as we increase in unit to pixel ratio (i.e. as we go from CM to M to KM)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Ortho.AutoPlanes.ShiftPlanes": {
      "name": "r.Ortho.AutoPlanes.ShiftPlanes",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Shifts the whole frustum in the Z direction.This can be useful if, for example you need the Near plane closer to the camera, at the reduction of the Far plane value (e.g. a horizontal 2.5D scene).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
