    "r.SkyLight.RealTimeReflectionCapture.TimeSlice.SkyCloudCubeFacePerFrame": {
      "name": "r.SkyLight.RealTimeReflectionCapture.TimeSlice.SkyCloudCubeFacePerFrame",
      "kind": "variable",
      "type": "int",
      "defaultValue": "6",
      "help": "When enabled, the real-time sky light capture, when time sliced, will not render cloud in all cube face in a single frame; but one face per frame. That is to distribute the cloud tracing cost even more, but will add latency and potentially can result in lighting discrepancy between faces if the sun is moving fast. Value in [1,6].",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
