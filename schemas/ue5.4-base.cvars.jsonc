      "name": "r.SparseVolumeTexture.Streaming.ReservedResourcesMemoryLimit",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Memory limit in MiB on the maximum size of the streaming pool textures when using reserved resources. Without this limit it is theoretically possible to allocate enormous amounts of memory. Set to -1 to disable the limit. Default: -1",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
