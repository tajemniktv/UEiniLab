    "r.OptimizedWPO.AffectNonNaniteShaderSelection": {
      "name": "r.OptimizedWPO.AffectNonNaniteShaderSelection",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "false",
      "help": "Whether the per primitive WPO flag should affect shader selection for non-nanite primitives. It increase the chance of selecting the position only depth VS at the cost of updating cached draw commands whenever the WPO flag changes.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
