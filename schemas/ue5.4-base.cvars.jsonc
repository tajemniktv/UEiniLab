      "name": "np2.PredictiveInterpolation.ErrorAccLinVelMaxLimit",
      "kind": "variable",
      "type": "int",
      "defaultValue": "50",
      "help": "If target velocity is below this limit we check for desync to trigger softsnap and accumulate time to build up to a hardsnap.",
