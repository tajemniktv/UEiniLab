      "name": "r.RayTracing.Translucency.Shadows",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Enables shadows in ray tracing translucency) -1: Shadows driven by postprocessing volume (default) 0: Shadows disabled 1: Hard shadows 2: Soft area shadows",
