    },
    "r.Shadow.TranslucentPerObject.ProjectEnabled": {
      "name": "r.Shadow.TranslucentPerObject.ProjectEnabled",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enable/Disable translucency shadows on a per-project basis. Turning off can significantly reduce the number of permutations if your project has many translucent materials.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
