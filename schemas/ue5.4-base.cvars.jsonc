      "name": "landscape.DirtyHeightmapNormalThreshold",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Threshold to avoid imprecision issues on certain GPUs when detecting when a heightmap normal changes, i.e. only a normal channel difference > than this threshold (N over each 8-bits uint B & A channels independently) will be detected as a change.",
      "category": "Landscape",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
