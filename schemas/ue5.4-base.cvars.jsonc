    "net.AllowEncryption": {
      "name": "net.AllowEncryption",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "If true, the engine will attempt to load an encryption PacketHandler component and fill in the EncryptionToken parameter of the NMT_Hello message based on the ?EncryptionToken= URL option and call callbacks if it's non-empty. Additionally, a value of '2' will make the EncryptionToken required - which is enforced serverside. (0 = Disabled, 1 = Allowed (default), 2 = Required)",
      "category": "Networking",
