    "r.Upscale.Panini.D": {
      "name": "r.Upscale.Panini.D",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Allow and configure to apply a panini distortion to the rendered image. Values between 0 and 1 allow to fade the effect (lerp). Implementation from research paper Pannini: A New Projection for Rendering Wide Angle Perspective Images\" 0: off (default) >0: enabled (requires an extra post processing pass if upsampling wasn't used - see r.ScreenPercentage) 1: Panini cylindrical stereographic projection\"",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Upscale.Panini.S": {
      "name": "r.Upscale.Panini.S",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Panini projection's hard vertical compression factor. 0: no vertical compression factor (default) 1: Hard vertical compression",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
