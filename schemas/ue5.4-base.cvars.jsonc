      "name": "np2.PredictiveInterpolation.ExtrapolationTimeMultiplier",
      "kind": "variable",
      "type": "int",
      "defaultValue": "3",
      "help": "Multiplier to adjust the time to extrapolate the target forward over, the time is based on current send-rate.",
