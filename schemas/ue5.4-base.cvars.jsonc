      "name": "np2.PredictiveInterpolation.ErrorAccumulationSeconds",
      "kind": "variable",
      "type": "int",
      "defaultValue": "3",
      "help": "Perform a reposition if replication have not been able to cover the min expected distance towards the target for this amount of time.",
