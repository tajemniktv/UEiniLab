    "r.RDG.AsyncCompute": {
      "name": "r.RDG.AsyncCompute",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Controls the async compute policy. 0:disabled, no async compute is used; 1:enabled for passes tagged for async compute (default); 2:enabled for all compute passes implemented to use the compute command list;",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
