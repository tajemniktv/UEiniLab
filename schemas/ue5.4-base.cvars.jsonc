    "r.Shaders.AllowCompilingThroughWorkers": {
      "name": "r.Shaders.AllowCompilingThroughWorkers",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Allows shader compilation through external ShaderCompileWorker processes. 1 - (Default) Allows external shader compiler workers 0 - Disallows external shader compiler workers. Will run shader compilation in proc of UE process.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.AllowUniqueSymbols": {
      "name": "r.Shaders.AllowUniqueSymbols",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When enabled, this tells supported shader compilers to generate symbols based on source files. Enabling this can cause a drastic increase in the number of symbol files, enable only if absolutely necessary. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.BoundsChecking": {
      "name": "r.Shaders.BoundsChecking",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether to enforce bounds-checking & flush-to-zero/ignore for buffer reads & writes in shaders. Defaults to 1 (enabled). Not all shader languages can omit bounds checking.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.CheckLevel": {
      "name": "r.Shaders.CheckLevel",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "0 => DO_CHECK=0, DO_GUARD_SLOW=0, 1 => DO_CHECK=1, DO_GUARD_SLOW=0, 2 => DO_CHECK=1, DO_GUARD_SLOW=1 for all shaders.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.ExtraData": {
      "name": "r.Shaders.ExtraData",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables generation of extra shader data that can be used at runtime. This includes shader names and other platform specific data. This can add bloat to compiled shaders and can prevent shaders from being deduplicated. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.FastMath": {
      "name": "r.Shaders.FastMath",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether to use fast-math optimisations in shaders.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.FlowControlMode": {
      "name": "r.Shaders.FlowControlMode",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Specifies whether the shader compiler should preserve or unroll flow-control in shader code. This is primarily a debugging aid and will override any per-shader or per-material settings if not left at the default value (0). 0: Off (Default) - Entirely at the discretion of the platform compiler or the specific shader/material. 1: Prefer - Attempt to preserve flow-control. 2: Avoid - Attempt to unroll and flatten flow-control.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.ForceDXC": {
      "name": "r.Shaders.ForceDXC",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Forces DirectX Shader Compiler (DXC) to be used for all shaders instead of HLSLcc if supported. 1: Force new compiler for all shaders (default) 0: Disable",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.GenerateSymbols": {
      "name": "r.Shaders.GenerateSymbols",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables generation of data for shader debugging when compiling shaders. This explicitly does not write any shader symbols to disk. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.Optimize": {
      "name": "r.Shaders.Optimize",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether to optimize shaders. When using graphical debuggers like Nsight it can be useful to disable this on startup. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.PropagateLocalWorkerOOMs": {
      "name": "r.Shaders.PropagateLocalWorkerOOMs",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "false",
      "help": "When set, out-of-memory conditions in a local shader compile worker will be treated as regular out-of-memory conditions and propagated to the main process. This is useful when running in environment with hard memory limits, where it does not matter which process in particular caused us to violate the memory limit.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.RemoveDeadCode": {
      "name": "r.Shaders.RemoveDeadCode",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Run a preprocessing step that removes unreferenced code before compiling shaders. This can improve the compilation speed for shaders which include many large utility headers. 0: Keep all input source code. 1: Remove unreferenced code before compilation (Default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.RemoveUnusedInterpolators": {
      "name": "r.Shaders.RemoveUnusedInterpolators",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enables removing unused interpolators mode when compiling shader pipelines. 0: Disable (default) 1: Enable removing unused",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.SkipCompression": {
      "name": "r.Shaders.SkipCompression",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Skips shader compression after compiling. Shader compression time can be quite significant when using debug shaders. This CVar is only valid in non-shipping/test builds.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.SymbolPathOverride": {
      "name": "r.Shaders.SymbolPathOverride",
      "kind": "variable",
      "type": "unknown",
      "defaultValue": " ",
      "help": "Override output location of shader symbols. If the path contains the text '{Platform}', that will be replaced with the shader platform string. Empty: use default location Saved/ShaderSymbols/{Platform} This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.Symbols": {
      "name": "r.Shaders.Symbols",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables debugging of shaders in platform specific graphics debuggers. This will generate and write shader symbols. This enables the behavior of both r.Shaders.GenerateSymbols and r.Shaders.WriteSymbols. Enables shader debugging features that require shaders to be recompiled. This compiles shaders with symbols and also includes extra runtime information like shader names. When using graphical debuggers it can be useful to enable this on startup. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.SymbolsInfo": {
      "name": "r.Shaders.SymbolsInfo",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "In lieu of a full set of platform shader PDBs, save out a slimmer ShaderSymbols.Info which contains shader platform hashes and shader debug info. An option for when it is not practical to save PDBs for shaders all the time. This setting can be overriden in any Engine.ini under the [ShaderCompiler] section.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.UseGBufferRefactor": {
      "name": "r.Shaders.UseGBufferRefactor",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Whether to use the refactored GBuffer that autogenerates encode/decode functions. Will be removed before UE5 ships.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.Validation": {
      "name": "r.Shaders.Validation",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enabled shader compiler validation warnings and errors.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shaders.WarningsAsErrors": {
      "name": "r.Shaders.WarningsAsErrors",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Whether to treat warnings as errors when compiling shaders. (0: disabled (default), 1: global shaders only, 2: all shaders)). This setting may be ignored on older platforms.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
