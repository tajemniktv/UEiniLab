      "kind": "variable",
      "type": "int",
      "defaultValue": "5",
      "help": "Window size in SVT frames around which requests to a SVT are considered to belong to the same instance. A streaming instance is an internal book keeping object to track playback of a SVT asset in a given context. Default: 5.0",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
