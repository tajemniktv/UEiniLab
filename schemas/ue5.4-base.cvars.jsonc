    "r.PathTracing.DecalGrid.Visualize": {
      "name": "r.PathTracing.DecalGrid.Visualize",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables a visualization mode of the decal grid density where red indicates the maximum decal count has been reached (default = 0) 0: off (default) 1: decal count heatmap (red - close to overflow, increase r.RayTracing.DecalGrid.MaxCount) 2: unique decal lists (colors are a function of which decals occupy each cell)",
