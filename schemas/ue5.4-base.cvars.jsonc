    "r.RHICmdFlushRenderThreadTasks": {
      "name": "r.RHICmdFlushRenderThreadTasks",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "If true, then we flush the render thread tasks every pass. For issue diagnosis. This is a main switch for more granular cvars.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
