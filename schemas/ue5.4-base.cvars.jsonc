      "name": "D3D12.PSO.StallWarningThresholdInMs",
      "kind": "variable",
      "type": "int",
      "defaultValue": "100",
      "help": "Sets a threshold of when to logs messages about stalls due to PSO creation. Value is in milliseconds. (100 is the default)",
      "category": "D3D12",
