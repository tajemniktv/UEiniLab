    "r.ShaderCompiler.DebugDiscardCacheOutputs": {
      "name": "r.ShaderCompiler.DebugDiscardCacheOutputs",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "if != 0, cache outputs are discarded (not added to the output map) for debugging purposes. Eliminates usefulness of the cache, but allows repeated triggering of the same jobs for stress testing (for example, rapid undo/redo in the Material editor).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
