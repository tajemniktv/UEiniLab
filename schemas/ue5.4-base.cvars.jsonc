      "name": "fx.Niagara.Batcher.TickFlush.MaxQueuedFrames",
      "kind": "variable",
      "type": "int",
      "defaultValue": "3",
      "help": "The number of unprocessed frames with queued ticks before we process them. The larger the number the more data we process in a single frame, this is generally only a concern when the application does not have focus.",
      "category": "FX",
      "availability": {
        "engineVersions": [
          "5.4"
