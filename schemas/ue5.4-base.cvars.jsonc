    "r.PathTracing.LightGridResolution": {
      "name": "r.PathTracing.LightGridResolution",
      "kind": "variable",
      "type": "int",
      "defaultValue": "256",
      "help": "Controls the resolution of the 2D light grid used to cull irrelevant lights from lighting calculations (default = 256)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
