    "D3D12.PSO.DiskCache": {
      "name": "D3D12.PSO.DiskCache",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables a disk cache for Pipeline State Objects (PSOs). PSO descs are cached to disk so subsequent runs can create PSOs at load-time instead of at run-time. This cache contains data that is independent of hardware, driver, or machine that it was created on. It can be distributed with shipping content. 0 to disable the pipeline state disk cache 1 to enable the pipeline state disk cache (default)",
      "category": "D3D12",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "D3D12.PSO.DriverOptimizedDiskCache": {
      "name": "D3D12.PSO.DriverOptimizedDiskCache",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Enables a disk cache for driver-optimized Pipeline State Objects (PSOs). PSO descs are cached to disk so subsequent runs can create PSOs at load-time instead of at run-time. This cache contains data specific to the hardware, driver, and machine that it was created on. 0 to disable the driver-optimized pipeline state disk cache 1 to enable the driver-optimized pipeline state disk cache",
      "category": "D3D12",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
