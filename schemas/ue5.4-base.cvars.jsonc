    "r.VelocityOutputPass": {
      "name": "r.VelocityOutputPass",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When to write velocity buffer. 0: Renders during the depth pass. This splits the depth pass into 2 phases: with and without velocity. 1: Renders during the regular base pass. This adds an extra GBuffer target during base pass rendering. 2: Renders after the regular base pass.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
