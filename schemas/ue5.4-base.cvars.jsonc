          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.UnbuiltNumWholeSceneDynamicShadowCascades": {
      "name": "r.Shadow.UnbuiltNumWholeSceneDynamicShadowCascades",
      "kind": "variable",
      "type": "int",
      "defaultValue": "4",
      "help": "DynamicShadowCascades to use when using CSM to preview unbuilt lighting from a directional light",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Shadow.UnbuiltPreviewInGame": {
      "name": "r.Shadow.UnbuiltPreviewInGame",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether to render unbuilt preview shadows in game. When enabled and lighting is not built, expensive preview shadows will be rendered in game. When disabled, lighting in game and editor won't match which can appear to be a bug.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
