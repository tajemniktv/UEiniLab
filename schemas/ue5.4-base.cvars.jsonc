      "name": "r.RayTracing.Nanite.BLASScratchSizeMultipleMB",
      "kind": "variable",
      "type": "int",
      "defaultValue": "64",
      "help": "Round the size of the BLAS build scratch buffer to be a multiple of this value. This helps maintain consistent memory usage and prevent memory usage spikes. Default = 64 MB.",
