    "r.Shadow.UnbuiltWholeSceneDynamicShadowRadius": {
      "name": "r.Shadow.UnbuiltWholeSceneDynamicShadowRadius",
      "kind": "variable",
      "type": "int",
      "defaultValue": "200000",
      "help": "WholeSceneDynamicShadowRadius to use when using CSM to preview unbuilt lighting from a directional light",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
