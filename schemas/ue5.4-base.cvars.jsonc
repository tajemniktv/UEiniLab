    "r.Velocity.ForceOutput": {
      "name": "r.Velocity.ForceOutput",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Force velocity output on all primitives. This can incur a performance cost unless r.VelocityOutputPass=1. But it can be useful for testing where velocity output isn't being enabled as expected. 0: Disabled (default) 1: Enabled",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
