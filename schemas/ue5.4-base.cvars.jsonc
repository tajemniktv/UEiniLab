      "name": "r.SparseVolumeTexture.Streaming.RequestSizeGranularity",
      "kind": "variable",
      "type": "int",
      "defaultValue": "131072",
      "help": "Rounds up calculated streaming request sizes to a multiple of this value (in bytes). This avoids performance issues where the system might issue multiple very small requests.",
