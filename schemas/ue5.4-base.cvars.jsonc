    "np2.PredictiveInterpolation.FakeTargetOnClientWakeUp": {
      "name": "np2.PredictiveInterpolation.FakeTargetOnClientWakeUp",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "false",
      "help": "When true, predictive interpolation will fake a replication target at the current transform marked as asleep, this target only apply if the client doesn't receive targets from the server. This stops the client from desyncing from the server if being woken up by mistake",
      "category": "Networked Physics",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
