    "net.UseRecvMulti": {
      "name": "net.UseRecvMulti",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "If true, and if running on a Unix/Linux platform, multiple packets will be retrieved from the socket with one syscall, improving performance and also allowing retrieval of timestamp information.",
