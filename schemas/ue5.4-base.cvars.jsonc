    "rhi.SyncInterval": {
      "name": "rhi.SyncInterval",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Determines the frequency of VSyncs in supported RHIs. This is in multiples of 16.66 on a 60hz display, but some platforms support higher refresh rates. Assuming 60fps, the values correspond to: 0 - Unlocked (present immediately) 1 - Present every vblank interval 2 - Present every 2 vblank intervals 3 - etc...",
      "category": "RHI",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
