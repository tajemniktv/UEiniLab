      "name": "r.RayTracing.Translucency.MaxRefractionRays",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Sets the maximum number of refraction rays for ray traced translucency (default = -1 (max bounces driven by postprocessing volume)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
