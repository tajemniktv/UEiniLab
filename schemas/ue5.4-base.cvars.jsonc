    "r.PathTracing.Compaction": {
      "name": "r.PathTracing.Compaction",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enables path compaction to improve GPU occupancy for the path tracer (default: 1 (enabled))",
