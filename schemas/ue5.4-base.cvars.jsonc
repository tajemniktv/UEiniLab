      "name": "r.PathTracing.SpatialDenoiser.Type",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "The type of spatial denoiser 0: Use spatial denoiser only plugin 1: Use spatial denoiser plugin that also provides temporal denoising",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
