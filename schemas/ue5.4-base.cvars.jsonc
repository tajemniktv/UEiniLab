    "r.DumpShaderDebugInfo": {
      "name": "r.DumpShaderDebugInfo",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Dumps debug info for compiled shaders to GameName/Saved/ShaderDebugInfo When set to 1, debug info is dumped for all compiled shader When set to 2, it is restricted to shaders with compilation errors When set to 3, it is restricted to shaders with compilation errors or warnings The debug info is platform dependent, but usually includes a preprocessed version of the shader source. Global shaders automatically dump debug info if r.ShaderDevelopmentMode is enabled, this cvar is not necessary. On iOS, if the PowerVR graphics SDK is installed to the default path, the PowerVR shader compiler will be called and errors will be reported during the cook.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
