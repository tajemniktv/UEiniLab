    "r.RayTracing.Translucency.MaxRoughness": {
      "name": "r.RayTracing.Translucency.MaxRoughness",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Sets the maximum roughness until which ray tracing reflections will be visible (default = -1 (max roughness driven by postprocessing volume))",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
