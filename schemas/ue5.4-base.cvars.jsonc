    "r.GenerateMeshDistanceFields": {
      "name": "r.GenerateMeshDistanceFields",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Whether to build distance fields of static meshes, needed for Lumen Software Ray Tracing and Distance Field AO, which is used to implement Movable SkyLight shadows. Enabling will increase mesh build times and memory usage. Changing this value will cause a rebuild of all static meshes.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
