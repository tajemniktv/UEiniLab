      "name": "np2.PredictiveInterpolation.InterpolationTimeMultiplier",
      "kind": "variable",
      "type": "float",
      "defaultValue": "1.1",
      "help": "Multiplier to adjust the replication interpolation time which is based on the sendrate of replication data from the server.",
