    "r.Nanite.VisualizeOverview": {
      "name": "r.Nanite.VisualizeOverview",
      "kind": "variable",
      "type": "string",
      "defaultValue": "\"Triangles,Clusters,Instances,Primitives,,,,,,,,,Overdraw,MaterialID,RasterBins,EvaluateWPO\"",
      "help": "Specify the list of modes that can be used in the Nanite visualization overview. Put nothing between the commas to leave a gap. Choose from: Overview, Mask, Triangles, Patches, Clusters, Primitives, Instances, Overdraw, MaterialID, LightmapUV, EvaluateWPO, PixelProgrammable, Picking, Groups, Pages, Hierarchy, RasterMode, RasterBins, ShadingBins, SceneZMin, SceneZMax, SceneZDelta, SceneZDecoded, MaterialZMin, MaterialZMax, MaterialZDelta, MaterialZDecoded, MaterialCount, MaterialMode, MaterialIndex, HitProxyID, LightmapUVIndex, LightmapDataIndex, PositionBits, VSMStatic, ShadingWriteMask, NoDerivativeOps, FastClearTiles, Tessellation, DisplacementScale.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.Nanite.VSMInvalidateOnLODDelta": {
      "name": "r.Nanite.VSMInvalidateOnLODDelta",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Experimental: Clusters that are not streamed in to LOD matching the computed Nanite LOD estimate will trigger VSM invalidation such that they are re-rendered when streaming completes. NOTE: May cause a large increase in invalidations in cases where the streamer has difficulty keeping up (a future version will need to throttle the invalidations and/or add a threshold).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing": {
      "name": "r.PathTracing",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Enables the path tracing renderer (to guard the compilation of path tracer specific material permutations)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.AdaptiveSampling": {
      "name": "r.PathTracing.AdaptiveSampling",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Determines if adaptive sampling is enabled. When non-zero, the path tracer will try to skip calculation of pixels below the specified error threshold. 0: off (uniform sampling - default) 1: on (adaptive sampling)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.AdaptiveSampling.ErrorThreshold": {
      "name": "r.PathTracing.AdaptiveSampling.ErrorThreshold",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.001",
      "help": "This is the target perceptual error threshold. Once a pixel's error falls below this value, it will not be sampled again (default: 0.001)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.AdaptiveSampling.Visualize": {
      "name": "r.PathTracing.AdaptiveSampling.Visualize",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Select a visualization mode to help understand how adaptive sampling is working. 0: off 1: Visualize active pixels with heatmap (converged pixels are displayed as is) 2: Visualize sample count heatmap (against current max samples) 3-7: Visualize variance mip levels",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.AdjustMultiGPUPasses": {
      "name": "r.PathTracing.AdjustMultiGPUPasses",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "true",
      "help": "Run extra passes per frame when multiple GPUs are active, to improve perf scaling as GPUs are added (default = true)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.ApproximateCaustics": {
      "name": "r.PathTracing.ApproximateCaustics",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "When non-zero, the path tracer will approximate caustic paths to reduce noise. This reduces speckles and noise from low-roughness glass and metals. (default = 1 (enabled))",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.AtmosphereOpticalDepthLUTNumSamples": {
      "name": "r.PathTracing.AtmosphereOpticalDepthLUTNumSamples",
      "kind": "variable",
      "type": "int",
      "defaultValue": "16384",
      "help": "Number of ray marching samples used when building the transmittance lookup texture used for transmittance calculations by the path tracer in reference atmosphere mode. (default = 16384)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
