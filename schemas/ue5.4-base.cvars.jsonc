    "r.PathTracing.TemporalDenoiser.PatchCount": {
      "name": "r.PathTracing.TemporalDenoiser.PatchCount",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "The number of similar patches found by Non-Local Mean to use for temporal denoising 1: default. Accumulae the one with the minimal distance exponentially.>1 && < 16: Use bilaterial filtering to accumulate multiple patches.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
