      "name": "r.SSS.Burley.MinGenerateMipsTileCount",
      "kind": "variable",
      "type": "int",
      "defaultValue": "4000",
      "help": "4000. (default) The minimal number of tiles to trigger subsurface radiance mip generation. Set to zero to always generate mips (Experimental value)",
