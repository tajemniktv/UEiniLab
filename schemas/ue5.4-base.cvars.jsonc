      "defaultValue": "1",
      "help": "For Multi-GPU, controls which GPUs TLAS and material pipeline updates run on. (default = 1) 0: Run TLAS and material pipeline updates on all GPUs. Original behavior, which may be useful for debugging. 1: Run TLAS and material pipeline updates masked to the active view's GPUs to improve performance. BLAS updates still run on all GPUs.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
