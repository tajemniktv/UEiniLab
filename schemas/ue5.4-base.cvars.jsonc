    "np2.NumRedundantCmds": {
      "name": "np2.NumRedundantCmds",
      "kind": "variable",
      "type": "int",
      "defaultValue": "3",
      "help": "(DEPRECATED 5.4, only part of the legacy physics frame offset logic) Number of redundant user cmds to send per frame",
      "category": "Networked Physics",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
