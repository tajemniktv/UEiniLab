    "r.GeneralPurposeTweak": {
      "name": "r.GeneralPurposeTweak",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Useful for low level shader development to get quick iteration time without having to change any c++ code. Value maps to Frame.GeneralPurposeTweak inside the shaders. Example usage: Multiplier on some value to tweak, toggle to switch between different algorithms (Default: 1.0) DON'T USE THIS FOR ANYTHING THAT IS CHECKED IN. Compiled out in SHIPPING to make cheating a bit harder.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.GeneralPurposeTweak2": {
      "name": "r.GeneralPurposeTweak2",
      "kind": "variable",
      "type": "int",
      "defaultValue": "1",
      "help": "Useful for low level shader development to get quick iteration time without having to change any c++ code. Value maps to Frame.GeneralPurposeTweak2 inside the shaders. Example usage: Multiplier on some value to tweak, toggle to switch between different algorithms (Default: 1.0) DON'T USE THIS FOR ANYTHING THAT IS CHECKED IN. Compiled out in SHIPPING to make cheating a bit harder.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
