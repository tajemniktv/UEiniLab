      "name": "au.streamcaching.MaxCachesToDisplay",
      "kind": "variable",
      "type": "int",
      "defaultValue": "128",
      "help": "Sets the max amount of stream chunks to display on screen. n: Number of elements to display on screen.",
      "category": "Audio",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
