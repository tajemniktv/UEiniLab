      "kind": "variable",
      "type": "int",
      "defaultValue": "10",
      "help": "Lower values cause the temporal filter to propagate lighting changes faster, but also increase flickering from noise.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
