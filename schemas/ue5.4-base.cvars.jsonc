    "r.VolumetricCloud.DistanceToSampleMaxCount": {
      "name": "r.VolumetricCloud.DistanceToSampleMaxCount",
      "kind": "variable",
      "type": "int",
      "defaultValue": "15",
      "help": "Distance in kilometers over which the total number of ray samples will be evenly distributed. Before that, the number of ray samples will span 1 to SampleCountMax, for for tracing distance ranging from 0 to DistanceToSampleCountMax (kilometers).",
