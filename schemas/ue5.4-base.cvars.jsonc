    "r.SSS.Burley.NumSamplesOverride": {
      "name": "r.SSS.Burley.NumSamplesOverride",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When zero, Burley SSS adaptively determines the number of samples. When non-zero, this value overrides the sample count.",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
