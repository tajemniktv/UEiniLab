    "r.SSS.SampleSet": {
      "name": "r.SSS.SampleSet",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Defines how many samples we use for Separable Screenspace Subsurface Scattering feature. 0: lowest quality (62+1) 1: medium quality (92+1) 2: high quality (13*2+1) (default)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
