      "name": "r.SparseVolumeTexture.Streaming.RequestSize",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "IO request size in KiB. The SVT streaming manager will attempt to create IO requests of roughly this size. Default: -1 (unlimited)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
