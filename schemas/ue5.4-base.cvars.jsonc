    "r.PathTracing.MaxRaymarchSteps": {
      "name": "r.PathTracing.MaxRaymarchSteps",
      "kind": "variable",
      "type": "int",
      "defaultValue": "256",
      "help": "Upper limit on the number of ray marching steps in volumes. This limit should not be hit in most cases, but raising it can reduce bias in case it is. (default = 256).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.MaxSSSBounces": {
      "name": "r.PathTracing.MaxSSSBounces",
      "kind": "variable",
      "type": "int",
      "defaultValue": "256",
      "help": "Sets the maximum number of bounces inside subsurface materials. Lowering this value can make subsurface scattering render too dim, while setting it too high can cause long render times. (default = 256)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
