      "name": "np2.PredictiveInterpolation.DisableSoftSnap",
      "kind": "variable",
      "type": "bool",
      "defaultValue": "false",
      "help": "When true, predictive interpolation will not use softsnap to correct the replication with when velocity fails. Hardsnap will still eventually kick in if replication can't reach the target.",
