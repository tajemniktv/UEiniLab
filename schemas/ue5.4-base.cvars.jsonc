    "r.SSS.Burley.AlwaysUpdateParametersFromSeparable": {
      "name": "r.SSS.Burley.AlwaysUpdateParametersFromSeparable",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "0: Will not update parameters when the program loads. (default)1: Always update from the separable when the program loads. (Correct only when Subsurface color is 1).",
