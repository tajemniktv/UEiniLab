      "name": "r.EyeAdaptation.LensAttenuation",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.78",
      "help": "The camera lens attenuation (q). Set this number to 0.78 for lighting to be unitless (1.0cd/m^2 becomes 1.0 at EV100) or 0.65 to match previous versions (1.0cd/m^2 becomes 1.2 at EV100).",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.EyeAdaptation.MethodOverride": {
      "name": "r.EyeAdaptation.MethodOverride",
      "kind": "variable",
      "type": "int",
      "defaultValue": "-1",
      "help": "Override the camera metering method set in post processing volumes -2: override with custom settings (for testing Basic Mode) -1: no override 1: Auto Histogram-based 2: Auto Basic 3: Manual",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.EyeAdaptation.PreExposureOverride": {
      "name": "r.EyeAdaptation.PreExposureOverride",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "Overide the scene pre-exposure by a custom value. = 0 : No override > 0 : Override PreExposure",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.EyeAdaptation.VisualizeDebugType": {
      "name": "r.EyeAdaptation.VisualizeDebugType",
      "kind": "variable",
      "type": "int",
      "defaultValue": "0",
      "help": "When enabling Show->Visualize->HDR (Eye Adaptation) is enabled, this flag controls the scene color. 0: Scene Color after tonemapping (default). 1: Histogram Debug",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.EyeAdaptationQuality": {
      "name": "r.EyeAdaptationQuality",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Defines the eye adaptation quality which allows to adjust for quality or performance. <=0: off (fastest) 1: low quality (e.g. non histogram based, not yet implemented) 2: normal quality (default) 3: high quality (e.g. screen position localized, not yet implemented)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.FastBlurThreshold": {
      "name": "r.FastBlurThreshold",
      "kind": "variable",
      "type": "int",
      "defaultValue": "100",
      "help": "Defines at what radius the Gaussian blur optimization kicks in (estimated 25% - 40% faster). The optimization uses slightly less memory and has a quality loss on smallblur radius. 0: use the optimization always (fastest, lowest quality) 3: use the optimization starting at a 3 pixel radius (quite fast) 7: use the optimization starting at a 7 pixel radius (default) >15: barely ever use the optimization (high quality)",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.FASTBuild.JobProcessor.MaxTimeWithPendingJobs": {
      "name": "r.FASTBuild.JobProcessor.MaxTimeWithPendingJobs",
      "kind": "variable",
      "type": "int",
      "defaultValue": "10",
      "help": "Specifies how much time in seconds we will wait to have the min amount of pending jobs. Past this time, the build will start anyways. Default = 10",
      "category": "Rendering",
      "availability": {
        "engineVersions": [
          "5.4"
