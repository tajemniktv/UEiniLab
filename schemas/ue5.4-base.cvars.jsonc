          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "r.PathTracing.DecalRoughnessCutoff": {
      "name": "r.PathTracing.DecalRoughnessCutoff",
      "kind": "variable",
      "type": "float",
      "defaultValue": "0.15",
      "help": "Do not evaluate decals beyond this roughness level to improve performance (default=0.15)",
