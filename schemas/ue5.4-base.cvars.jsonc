    "shaderpipeline.MinPrecompileTasksInFlight": {
      "name": "shaderpipeline.MinPrecompileTasksInFlight",
      "kind": "variable",
      "type": "int",
      "defaultValue": "10",
      "help": "Note: Only used when threadpool PSO precompiling is active. The number of active PSO precompile jobs in flight before we will submit another batch of jobs. i.e. when the number of inflight precompile tasks drops below this threshold we can add the next batch of precompile tasks. This is to prevent bubbles between precompile batches but also to avoid saturating dispatch.",
      "category": "Scalability Quality",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "ShowFlag.ActorColoration": {
      "name": "ShowFlag.ActorColoration",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Allows to override a specific showflag (works in editor and game, show\" only works in game and UI only in editor) Useful to run a build many time with the same showflags (when put in consolevariables.ini like \"showflag.abc=0\") 0: force the showflag to be OFF 1: force the showflag to be ON 2: do not override this showflag (default)\"",
      "category": "Show Flag",
      "availability": {
        "engineVersions": [
          "5.4"
        ]
      },
      "sources": [
        {
          "type": "engine-docs",
          "label": "Epic Unreal Engine 5.4 Console Variables Reference"
        }
      ]
    },
    "ShowFlag.AmbientCubemap": {
      "name": "ShowFlag.AmbientCubemap",
      "kind": "variable",
      "type": "int",
      "defaultValue": "2",
      "help": "Allows to override a specific showflag (works in editor and game, show\" only works in game and UI only in editor) Useful to run a build many time with the same showflags (when put in consolevariables.ini like \"showflag.abc=0\") 0: force the showflag to be OFF 1: force the showflag to be ON 2: do not override this showflag (default)\"",
      "category": "Show Flag",
