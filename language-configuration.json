{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\[.+\\]\\s*$",
      "end": "^\\s*(?=\\[.+\\])"
    }
  },
  "wordPattern": "([+\\-!])?([A-Za-z_][\\w.:-]*)"
}
